COMPOSE_PROJECT_NAME=iceberg

# S3 配置（连接 RustFS）
AWS_ACCESS_KEY_ID=rustfsadmin
AWS_SECRET_ACCESS_KEY=rustfsadmin
AWS_REGION=us-east-1

# Iceberg Catalog 配置
CATALOG_WAREHOUSE=s3://pb-bucket/
# Windows/Mac 使用 host.docker.internal 访问宿主机上的 RustFS
# Linux 如需使用 127.0.0.1，需配合 network_mode: host
CATALOG_S3_ENDPOINT=http://host.docker.internal:9000
CATALOG_S3_PATH_STYLE_ACCESS=true
