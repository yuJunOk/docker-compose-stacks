COMPOSE_PROJECT_NAME=rustfs

# 宿主机监听地址：默认 127.0.0.1；需局域网访问时可改为 0.0.0.0
RUSTFS_BIND=127.0.0.1

# 宿主机数据目录 → 容器 /data（相对路径相对本 compose 所在目录；可改为绝对路径，如 D:/data/rustfs）
RUSTFS_DATA_DIR=./rustfs_data

# 宿主机 -> 容器：S3 API 9000、控制台 9001
RUSTFS_PORT_9000=9000
RUSTFS_PORT_9001=9001

# S3 访问密钥（与 Spring access-key / secret-key 一致）；生产环境请改为强随机值，勿提交 .env
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
